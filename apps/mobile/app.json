{
  "expo": {
    "name": "Galaxia",
    "slug": "galaxia",
    "scheme": "galaxia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#191331"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.galaxia.app"
    },
    "android": {
      "package": "com.galaxia.app",
      "adaptiveIcon": {
        "backgroundColor": "#191331"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
